rules_version = '2';

// MASKD の Firestore セキュリティルール
// 適用方法: Firebase コンソール →「Firestore Database」→「ルール」タブに貼り付けて「公開」。
//   （または Firebase CLI: firebase deploy --only firestore:rules）
//
// 方針:
//   - 各コレクションとも「追加(create)」と「読み取り(read)」のみ許可
//   - update / delete は禁止（既存データの改ざん・削除を防ぐ）
//   - 「削除」が必要な場合も実体は書き換えず、hidden_records に新しいイベントを
//     追記する形の論理削除にする(admin.htmlの「非表示」機能はこの方式)
//   - 上記以外のコレクションは全面拒否
//   - 有効期限なし（テストモードのような自動失効はしない）
//   - create は最低限のバリデーションで不正・巨大データを弾く
//   - *_dev は develop プレビュー(/dev/)専用のコレクション。本番(logs/surveys/players/
//     hidden_records)とは完全に別物として扱い、集計やadmin.htmlの表示が混ざらないようにする。

service cloud.firestore {
  match /databases/{database}/documents {

    // プレイログ（匿名・集計用）
    match /logs/{docId} {
      allow read: if true;               // 「みんなの統計」/admin.htmlで集計表示（匿名データのみ）
      allow create: if isValidLog();     // 追加のみ許可
      allow update, delete: if false;    // 改ざん・削除は不可
    }
    match /logs_dev/{docId} {            // developプレビュー用(本番のlogsとは分離)
      allow read: if true;
      allow create: if isValidLog();
      allow update, delete: if false;
    }

    // アンケート回答（匿名）
    match /surveys/{docId} {
      allow read: if true;               // admin.htmlで集計表示。自由記述欄があるため読める点に注意
      allow create: if isValidSurvey();
      allow update, delete: if false;
    }
    match /surveys_dev/{docId} {         // developプレビュー用
      allow read: if true;
      allow create: if isValidSurvey();
      allow update, delete: if false;
    }

    // プレイヤー名登録（匿名）
    match /players/{docId} {
      allow read: if true;               // admin.htmlで登録人数・プレイ数を表示
      allow create: if isValidPlayer();
      allow update, delete: if false;
    }
    match /players_dev/{docId} {         // developプレビュー用
      allow read: if true;
      allow create: if isValidPlayer();
      allow update, delete: if false;
    }

    // 匿名の来訪カウント(同意不要)。playerId等の識別子は一切持たない
    // 「ページが開かれた回数」だけの記録。プレイログ(logs)の同意フローとは無関係。
    match /visits/{docId} {
      allow read: if true;
      allow create: if isValidVisit();
      allow update, delete: if false;
    }
    match /visits_dev/{docId} {          // developプレビュー用
      allow read: if true;
      allow create: if isValidVisit();
      allow update, delete: if false;
    }

    // 匿名のチュートリアル開始/段階クリアカウント(同意不要)。playerId等の識別子は持たない。
    // 既存のlogs内tutorial_start/tutorial_completeは同意ゲート+旧UIの計測で実質機能しなくなって
    // いたため、visitsと同じ「同意不要・匿名」方式で新設(v1.25.0)。v1.27.0で、完走の1点だけでなく
    // 各ステージ(1〜7)ごとのクリア人数を管理画面で見られるよう、段階別のカウントに拡張。
    // v1.30.0で、各ステージの開始(stage_start)、および所要時間/リトライ回数/チュートリアル版数
    // (elapsed_ms/retry_count/tutorial_version)を任意で記録できるよう拡張。
    match /tutorial_events/{docId} {
      allow read: if true;
      allow create: if isValidTutorialEvent();
      allow update, delete: if false;
    }
    match /tutorial_events_dev/{docId} { // developプレビュー用
      allow read: if true;
      allow create: if isValidTutorialEvent();
      allow update, delete: if false;
    }

    // admin.htmlの論理削除(非表示)イベント。対象データ自体は書き換えず、
    // 「hide」「unhide」のイベントを追記するだけ(最新のイベントが現在の状態)。
    match /hidden_records/{docId} {
      allow read: if true;
      allow create: if isValidHiddenRecord();
      allow update, delete: if false;
    }
    match /hidden_records_dev/{docId} {  // developプレビュー用
      allow read: if true;
      allow create: if isValidHiddenRecord();
      allow update, delete: if false;
    }

    // 上記以外はすべて拒否
    match /{document=**} {
      allow read, write: if false;
    }

    // プレイログの最低限のバリデーション。
    // 完了した対戦の記録(type:'game'、winner/playerFinal/cpuFinal必須)と、
    // 分析用の軽量イベント(session_start/game_start/abandon/tutorial_*、type必須・上記3項目は無し)の
    // どちらかであればOKとする(軽量イベントは元々このwinner等を持たない設計のため)。
    function isValidLog() {
      let d = request.resource.data;
      return d.size() <= 40               // フィールド数の上限（巨大ペイロード防止）
          && (
            ('winner' in d && d.winner in ['player', 'cpu', 'draw']
              && 'playerFinal' in d && d.playerFinal is number
              && 'cpuFinal' in d && d.cpuFinal is number)
            ||
            ('type' in d && d.type in ['session_start', 'game_start', 'abandon', 'tutorial_start', 'tutorial_complete'])
          );
    }

    // アンケートの最低限のバリデーション
    function isValidSurvey() {
      let d = request.resource.data;
      return 'fun' in d && d.fun is number && d.fun >= 1 && d.fun <= 5
          && d.size() <= 10;
    }

    // プレイヤー名登録の最低限のバリデーション
    function isValidPlayer() {
      let d = request.resource.data;
      return 'name' in d && d.name is string && d.name.size() <= 12
          && d.size() <= 5;
    }

    // 来訪カウントの最低限のバリデーション。playerId等の識別子フィールドは明示的に禁止する
    function isValidVisit() {
      let d = request.resource.data;
      return d.size() <= 3 && !('playerId' in d);
    }

    // チュートリアル開始/ステージ開始/段階クリア/STAGE1誘導フロー内の各操作カウントの最低限のバリデーション。
    // playerIdは明示的に禁止する。stageを持つ型は、どのステージ(1〜7)かを必須で持つ。
    // tutorial_version/retry_count/elapsed_ms/attr/next_stageは、STAGE1改善版の効果測定用に追加した任意フィールド。
    function isValidTutorialEvent() {
      let d = request.resource.data;
      return d.size() <= 8 && 'type' in d
          && d.type in ['start', 'complete', 'stage_clear', 'stage_start',
                         'card_confirm', 'decide_confirm', 'result_detail_open', 'stage_advance']
          && !('playerId' in d)
          && (!('stage' in d) || (d.stage is int && d.stage >= 1 && d.stage <= 7))
          && (!(d.type in ['stage_clear','stage_start','card_confirm','decide_confirm','result_detail_open','stage_advance']) || 'stage' in d)
          && (!('next_stage' in d) || (d.next_stage is int && d.next_stage >= 1 && d.next_stage <= 7))
          && (!('attr' in d) || (d.attr is string && d.attr in ['moon','sun','dark','kaos','air']))
          && (!('tutorial_version' in d) || (d.tutorial_version is string && d.tutorial_version.size() <= 8))
          && (!('retry_count' in d) || (d.retry_count is int && d.retry_count >= 0 && d.retry_count <= 999))
          && (!('elapsed_ms' in d) || (d.elapsed_ms is int && d.elapsed_ms >= 0 && d.elapsed_ms <= 3600000));
    }

    // 論理削除イベントの最低限のバリデーション
    function isValidHiddenRecord() {
      let d = request.resource.data;
      return 'col' in d && d.col in ['logs', 'surveys', 'players']
          && 'docId' in d && d.docId is string
          && 'action' in d && d.action in ['hide', 'unhide']
          && d.size() <= 5;
    }
  }
}
